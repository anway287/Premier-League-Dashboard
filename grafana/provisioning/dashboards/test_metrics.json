{
  "title": "Hermetic Test Framework — Sports Pipeline",
  "uid": "hermetic-sports-001",
  "tags": ["testing", "sports", "ci"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Pass Rate",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 0.8  },
              { "color": "green",  "value": 0.95 }
            ]
          },
          "mappings": []
        }
      },
      "targets": [
        {
          "expr": "test_pass_rate",
          "legendFormat": "Pass Rate",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Tests",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      },
      "targets": [
        {
          "expr": "test_total",
          "legendFormat": "Total",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Passed",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      },
      "targets": [
        {
          "expr": "test_passed_total",
          "legendFormat": "Passed",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Failed",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      },
      "targets": [
        {
          "expr": "test_failed_total",
          "legendFormat": "Failed",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Session Duration",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "fixed", "fixedColor": "orange" }
        }
      },
      "targets": [
        {
          "expr": "test_session_duration_seconds",
          "legendFormat": "Duration",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Pass Rate Over Time",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "spanNulls": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 0.95 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "expr": "test_pass_rate",
          "legendFormat": "Pass Rate",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Test Counts Over Time",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Failed" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Passed" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Skipped" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }]
          }
        ]
      },
      "targets": [
        { "expr": "test_passed_total", "legendFormat": "Passed",  "refId": "A" },
        { "expr": "test_failed_total", "legendFormat": "Failed",  "refId": "B" },
        { "expr": "test_skipped_total","legendFormat": "Skipped", "refId": "C" }
      ]
    },
    {
      "id": 8,
      "type": "bargauge",
      "title": "Slowest Tests (duration in seconds)",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "valueMode": "color"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1    },
              { "color": "red",    "value": 5    }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "expr": "topk(15, test_duration_seconds)",
          "legendFormat": "{{test}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Flaky Test Rate (failed / total per run)",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 7 },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "color": { "mode": "fixed", "fixedColor": "orange" }
        }
      },
      "targets": [
        {
          "expr": "test_failed_total / test_total",
          "legendFormat": "Flake Rate",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "type": "table",
      "title": "Latest Test Results",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 7 },
      "options": {
        "frameIndex": 0,
        "showHeader": true,
        "sortBy": [{ "displayName": "Duration", "desc": true }]
      },
      "fieldConfig": {
        "defaults": { "custom": { "width": 200 } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "outcome" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "passed":  { "text": "✓ passed",  "color": "green"  } } },
                  { "type": "value", "options": { "failed":  { "text": "✗ failed",  "color": "red"    } } },
                  { "type": "value", "options": { "skipped": { "text": "⊘ skipped", "color": "yellow" } } }
                ]
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "test_duration_seconds",
          "legendFormat": "{{test}} — {{outcome}}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ]
    }
  ]
}
